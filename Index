<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Clark's Cleaning Services — Lincoln & Surrounding Areas</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --cyan:#00B4D8;
    --cyan-mid:#0096C7;
    --cyan-deep:#0077B6;
    --navy:#1B3A5C;
    --navy-soft:#2A5080;
    --teal-light:#90E0EF;
    --teal-pale:#CAF0F8;
    --white:#FFFFFF;
    --off-white:#F0F8FF;
    --ink:#1B3A5C;
    --ink-soft:#4A6580;
    --line:rgba(0,180,216,0.15);
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{font-family:'Inter',sans-serif;background:var(--white);color:var(--ink);line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden;}
  h1,h2,h3{font-family:'Nunito',sans-serif;line-height:1.1;}
  a{color:inherit;text-decoration:none;}
  .wrap{max-width:1080px;margin:0 auto;padding:0 24px;}

  /* NAV */
  header{position:sticky;top:0;z-index:50;background:rgba(255,255,255,0.97);backdrop-filter:blur(8px);border-bottom:2px solid var(--teal-pale);}
  .nav{display:flex;align-items:center;justify-content:space-between;padding:12px 24px;max-width:1080px;margin:0 auto;}
  .logo{display:flex;align-items:center;gap:10px;}
  .logo-img{width:48px;height:48px;border-radius:10px;object-fit:cover;}
  .logo-text{font-family:'Nunito',sans-serif;font-size:1.15rem;font-weight:900;color:var(--navy);letter-spacing:-0.01em;}
  .logo-text span{color:var(--cyan);}
  .logo-sub{font-size:0.62rem;font-weight:600;color:var(--ink-soft);letter-spacing:0.08em;text-transform:uppercase;display:block;line-height:1;}
  .nav-links{display:flex;align-items:center;gap:24px;}
  .nav-links a{font-size:0.88rem;font-weight:600;color:var(--ink-soft);transition:color 0.2s;}
  .nav-links a:hover{color:var(--cyan);}
  .nav-cta{background:var(--cyan);color:var(--white)!important;padding:10px 22px;border-radius:100px;font-weight:700;font-size:0.88rem;transition:background 0.2s;box-shadow:0 4px 12px rgba(0,180,216,0.3);}
  .nav-cta:hover{background:var(--cyan-mid);}

  /* HERO */
  .hero{background:linear-gradient(135deg,var(--navy) 0%,var(--cyan-deep) 60%,var(--cyan-mid) 100%);padding:80px 24px 0;position:relative;overflow:hidden;}
  .hero::before{content:"";position:absolute;top:-100px;right:-100px;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(144,224,239,0.15) 0%,transparent 65%);pointer-events:none;}
  .hero::after{content:"";position:absolute;bottom:0;left:0;right:0;height:60px;background:var(--white);clip-path:ellipse(55% 100% at 50% 100%);}
  .hero-inner{max-width:1080px;margin:0 auto;display:grid;grid-template-columns:1.1fr 0.9fr;gap:48px;align-items:flex-end;position:relative;z-index:1;}
  .hero-left{padding-bottom:80px;}
  .hero-tag{display:inline-flex;align-items:center;gap:8px;background:rgba(144,224,239,0.15);border:1.5px solid rgba(144,224,239,0.3);border-radius:100px;padding:6px 16px;font-size:0.75rem;font-weight:700;color:var(--teal-light);letter-spacing:0.1em;text-transform:uppercase;margin-bottom:18px;}
  .hero-tag .dot{width:6px;height:6px;border-radius:50%;background:var(--teal-light);animation:blink 2s ease-in-out infinite;}
  @keyframes blink{0%,100%{opacity:1;}50%{opacity:0.3;}}
  .hero h1{font-size:clamp(2.2rem,4.5vw,3.6rem);color:var(--white);margin-bottom:8px;font-weight:900;}
  .hero h1 em{font-style:normal;color:var(--teal-light);}
  .hero-team{font-size:0.9rem;font-weight:600;color:rgba(255,255,255,0.7);margin-bottom:16px;letter-spacing:0.02em;}
  .hero-team span{color:var(--teal-light);}
  .hero-desc{color:rgba(255,255,255,0.7);font-size:1rem;max-width:44ch;margin-bottom:12px;line-height:1.7;}
  .hero-bullets{list-style:none;margin-bottom:32px;}
  .hero-bullets li{color:rgba(255,255,255,0.8);font-size:0.9rem;padding:4px 0;display:flex;align-items:center;gap:10px;font-weight:500;}
  .hero-bullets li::before{content:"✓";color:var(--teal-light);font-weight:800;}
  .hero-btns{display:flex;flex-wrap:wrap;gap:12px;align-items:center;}
  .btn-cyan{display:inline-flex;align-items:center;gap:8px;background:var(--cyan);color:var(--white);padding:14px 28px;border-radius:100px;font-weight:700;font-size:0.95rem;box-shadow:0 6px 20px rgba(0,180,216,0.35);transition:transform 0.2s,box-shadow 0.2s;}
  .btn-cyan:hover{transform:translateY(-2px);box-shadow:0 10px 28px rgba(0,180,216,0.45);}
  .btn-cyan svg{width:18px;height:18px;flex-shrink:0;}
  .btn-white-outline{color:rgba(255,255,255,0.8);font-weight:600;font-size:0.9rem;border:2px solid rgba(255,255,255,0.3);padding:12px 24px;border-radius:100px;transition:border-color 0.2s,color 0.2s;}
  .btn-white-outline:hover{border-color:var(--teal-light);color:var(--teal-light);}
  /* Hero right — team card -->
  .hero-card{background:rgba(255,255,255,0.1);backdrop-filter:blur(8px);border:1.5px solid rgba(255,255,255,0.15);border-radius:20px;padding:28px;text-align:center;margin-bottom:60px;}
  .hero-card-img{width:140px;height:140px;border-radius:50%;object-fit:cover;border:4px solid var(--teal-light);box-shadow:0 8px 24px rgba(0,0,0,0.2);margin:0 auto 16px;display:block;}
  .hero-card-name{font-family:'Nunito',sans-serif;font-size:1.1rem;font-weight:800;color:var(--white);margin-bottom:4px;}
  .hero-card-tag{font-size:0.8rem;color:rgba(255,255,255,0.6);margin-bottom:14px;}
  .hero-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(0,180,216,0.2);border:1px solid rgba(0,180,216,0.3);border-radius:100px;padding:7px 14px;font-size:0.78rem;font-weight:700;color:var(--teal-light);}

  /* HERO TEAM VISUAL */
  .hero-team-visual{
    position:relative;
    display:flex;
    flex-direction:column;
    align-items:center;
    padding-bottom:60px;
  }
  .hero-team-img{
    width:100%;
    max-width:420px;
    border-radius:20px;
    box-shadow:0 20px 60px rgba(0,0,0,0.3);
    border:3px solid rgba(255,255,255,0.2);
    display:block;
  }
  .hero-team-badge{
    margin-top:16px;
    background:rgba(255,255,255,0.12);
    backdrop-filter:blur(8px);
    border:1.5px solid rgba(255,255,255,0.2);
    border-radius:100px;
    padding:10px 24px;
    text-align:center;
  }
  .htb-name{
    font-family:'Nunito',sans-serif;
    font-weight:800;
    font-size:1rem;
    color:white;
    display:block;
  }
  .htb-sub{
    font-size:0.78rem;
    color:rgba(255,255,255,0.65);
    display:block;
  }
  @media(max-width:900px){.hero-team-visual{display:none;}}

  /* TEAM BANNER */
  .team-banner{position:relative;width:100%;overflow:hidden;max-height:420px;}
  .team-banner img{width:100%;max-height:420px;object-fit:cover;object-position:center 30%;display:block;}
  .team-banner-overlay{position:absolute;inset:0;background:linear-gradient(to right,rgba(27,58,92,0.85) 0%,rgba(0,119,182,0.65) 45%,rgba(0,150,199,0.2) 100%);}
  .team-banner-content{position:absolute;top:50%;left:5%;transform:translateY(-50%);max-width:500px;padding:0 24px;}
  .team-banner-title{font-family:"Nunito",sans-serif;font-size:clamp(1.8rem,4vw,3rem);font-weight:900;color:white;text-shadow:2px 3px 8px rgba(0,0,0,0.3);margin:10px 0 6px;line-height:1.1;}
  .team-banner-sub{color:rgba(255,255,255,0.9);font-size:1rem;font-weight:600;margin-bottom:4px;letter-spacing:0.02em;}

  /* TRUST BAR */
  .trust-bar{background:var(--cyan-deep);padding:16px 24px;}
  .trust-items{max-width:1080px;margin:0 auto;display:flex;flex-wrap:wrap;justify-content:center;gap:28px;}
  .trust-item{display:flex;align-items:center;gap:8px;font-size:0.82rem;font-weight:600;color:rgba(255,255,255,0.9);}

  /* SECTIONS */
  .section{padding:72px 24px;}
  .section-label{font-size:0.72rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:var(--cyan);margin-bottom:10px;display:flex;align-items:center;gap:10px;}
  .section-label::after{content:"";flex:1;max-width:36px;height:2px;background:var(--cyan);opacity:0.4;border-radius:1px;}
  .section-head h2{font-family:'Nunito',sans-serif;font-size:clamp(1.9rem,3.5vw,2.8rem);font-weight:900;margin-bottom:10px;color:var(--navy);}
  .section-head h2 em{font-style:normal;color:var(--cyan);}
  .section-head p{color:var(--ink-soft);font-size:0.97rem;max-width:52ch;margin-bottom:44px;}

  /* MEET THE TEAM */
  .team{background:var(--off-white);}
  .team-card{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;background:var(--white);border:2px solid var(--line);border-radius:20px;padding:40px;}
  .team-img{width:100%;aspect-ratio:1;border-radius:16px;overflow:hidden;border:3px solid var(--teal-pale);}
  .team-img img{width:100%;height:100%;object-fit:cover;}
  .team-content h3{font-family:'Nunito',sans-serif;font-size:1.6rem;font-weight:900;color:var(--navy);margin-bottom:8px;}
  .team-content p{color:var(--ink-soft);font-size:0.95rem;line-height:1.8;margin-bottom:20px;}
  .team-stats{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
  .team-stat{background:var(--off-white);border:1px solid var(--line);border-radius:10px;padding:14px;text-align:center;}
  .team-stat-num{font-family:'Nunito',sans-serif;font-size:1.6rem;font-weight:900;color:var(--cyan);display:block;line-height:1;}
  .team-stat-label{font-size:0.75rem;font-weight:600;color:var(--ink-soft);}

  /* SERVICES */
  .services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
  .svc-card{background:var(--white);border:2px solid var(--line);border-radius:16px;padding:24px;transition:border-color 0.2s,transform 0.2s,box-shadow 0.2s;}
  .svc-card:hover{border-color:var(--cyan);transform:translateY(-3px);box-shadow:0 12px 32px rgba(0,180,216,0.1);}
  .svc-icon{font-size:2rem;margin-bottom:12px;display:block;}
  .svc-card h3{font-family:'Nunito',sans-serif;font-size:1rem;font-weight:800;color:var(--navy);margin-bottom:8px;}
  .svc-card p{font-size:0.85rem;color:var(--ink-soft);line-height:1.6;margin:0;}
  .svc-tag{display:inline-block;margin-top:10px;font-size:0.72rem;font-weight:700;color:var(--cyan);background:var(--teal-pale);padding:3px 10px;border-radius:100px;}

  /* GALLERY */
  .gallery-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;}
  .gallery-item{position:relative;border-radius:14px;overflow:hidden;aspect-ratio:1;border:2px solid var(--line);}
  .gallery-item img{width:100%;height:100%;object-fit:cover;display:block;transition:transform 0.4s;}
  .gallery-item:hover img{transform:scale(1.05);}
  .gallery-item::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(27,58,92,0.6) 100%);pointer-events:none;}
  .gallery-caption{position:absolute;bottom:12px;left:14px;color:white;font-size:0.8rem;font-weight:700;z-index:1;}

  /* WHY */
  .why-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
  .why-item{background:var(--white);border:2px solid var(--line);border-radius:16px;padding:22px;text-align:center;transition:border-color 0.2s,box-shadow 0.2s;}
  .why-item:hover{border-color:var(--cyan);box-shadow:0 6px 20px rgba(0,180,216,0.1);}
  .why-icon{font-size:2rem;margin-bottom:12px;display:block;}
  .why-item h3{font-family:'Nunito',sans-serif;font-size:0.95rem;font-weight:800;color:var(--navy);margin-bottom:6px;}
  .why-item p{font-size:0.84rem;color:var(--ink-soft);margin:0;}

  /* PROCESS */
  .process{background:var(--off-white);}
  .process-steps{display:grid;grid-template-columns:repeat(4,1fr);position:relative;}
  .process-steps::before{content:"";position:absolute;top:25px;left:calc(12.5% + 12px);right:calc(12.5% + 12px);height:2px;background:var(--teal-pale);z-index:0;}
  .step{text-align:center;padding:0 12px;position:relative;z-index:1;}
  .step-circle{width:50px;height:50px;border-radius:50%;background:var(--white);border:2px solid var(--teal-pale);display:flex;align-items:center;justify-content:center;margin:0 auto 18px;font-family:'Nunito',sans-serif;font-size:1rem;font-weight:900;color:var(--cyan);transition:all 0.2s;box-shadow:0 2px 8px rgba(0,180,216,0.1);}
  .step:hover .step-circle{background:var(--cyan);border-color:var(--cyan);color:white;}
  .step h3{font-family:'Nunito',sans-serif;font-size:0.9rem;font-weight:800;color:var(--navy);margin-bottom:6px;}
  .step p{font-size:0.82rem;color:var(--ink-soft);margin:0;}

  /* PROMO */
  .promo-band{background:linear-gradient(135deg,var(--navy) 0%,var(--cyan-deep) 100%);padding:56px 24px;text-align:center;}
  .promo-badge-big{display:inline-block;background:var(--cyan);color:white;font-family:'Nunito',sans-serif;font-size:3rem;font-weight:900;padding:12px 32px;border-radius:16px;margin-bottom:12px;box-shadow:0 8px 24px rgba(0,180,216,0.4);}
  .promo-band h2{font-family:'Nunito',sans-serif;color:var(--white);font-size:clamp(1.8rem,3vw,2.6rem);font-weight:900;margin-bottom:10px;}
  .promo-band p{color:rgba(255,255,255,0.75);font-size:1rem;max-width:48ch;margin:0 auto 28px;}
  .promo-badges{display:flex;flex-wrap:wrap;justify-content:center;gap:12px;margin-bottom:28px;}
  .promo-badge{background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);border-radius:100px;padding:7px 18px;font-size:0.83rem;font-weight:600;color:white;}
  .btn-white{display:inline-flex;align-items:center;gap:10px;background:white;color:var(--cyan);padding:14px 32px;border-radius:100px;font-weight:700;font-size:0.95rem;transition:transform 0.2s,box-shadow 0.2s;}
  .btn-white:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,0.15);}
  .btn-white svg{width:20px;height:20px;}

  /* CONTACT */
  .contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start;}
  .contact-left h2{font-family:'Nunito',sans-serif;font-size:clamp(1.7rem,2.8vw,2.4rem);font-weight:900;margin-bottom:10px;color:var(--navy);}
  .contact-left h2 em{font-style:normal;color:var(--cyan);}
  .contact-left p{color:var(--ink-soft);margin-bottom:28px;font-size:0.95rem;}
  .contact-detail{display:flex;align-items:center;gap:14px;padding:14px 0;border-bottom:1px solid var(--line);}
  .contact-detail:last-child{border-bottom:none;}
  .cd-icon{width:42px;height:42px;border-radius:10px;background:var(--teal-pale);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1.1rem;}
  .cd-text{font-weight:700;color:var(--navy);font-size:0.95rem;}
  .cd-sub{font-size:0.82rem;color:var(--ink-soft);}
  .contact-right{background:linear-gradient(135deg,var(--navy) 0%,var(--cyan-deep) 100%);border-radius:20px;padding:32px;}
  .contact-right h3{font-family:'Nunito',sans-serif;color:white;font-size:1.3rem;font-weight:900;margin-bottom:8px;}
  .contact-right p{color:rgba(255,255,255,0.6);font-size:0.88rem;margin-bottom:22px;}
  .wa-btn{display:flex;align-items:center;gap:12px;background:#25D366;color:#0b3d1f;padding:15px 22px;border-radius:100px;font-weight:700;font-size:0.97rem;transition:transform 0.2s,box-shadow 0.2s;margin-bottom:12px;}
  .wa-btn:hover{transform:translateY(-2px);box-shadow:0 8px 20px rgba(37,211,102,0.3);}
  .wa-btn svg{width:22px;height:22px;flex-shrink:0;}
  .call-btn{display:flex;align-items:center;gap:12px;background:var(--cyan);color:white;padding:14px 22px;border-radius:100px;font-weight:700;font-size:0.95rem;transition:transform 0.2s;}
  .call-btn:hover{transform:translateY(-2px);}
  .urgency-note{margin-top:16px;padding:13px 17px;background:rgba(144,224,239,0.1);border-left:3px solid var(--teal-light);border-radius:0 8px 8px 0;font-size:0.83rem;color:rgba(255,255,255,0.6);}

  /* FOOTER */
  footer{background:var(--navy);padding:40px 24px 24px;}
  .footer-inner{max-width:1080px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr;gap:40px;margin-bottom:28px;}
  .footer-logo-wrap{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
  .footer-logo-img{width:40px;height:40px;border-radius:8px;object-fit:cover;}
  .footer-logo-text{font-family:'Nunito',sans-serif;font-size:1.1rem;font-weight:900;color:white;}
  .footer-logo-text span{color:var(--cyan);}
  .footer-desc{font-size:0.84rem;color:rgba(255,255,255,0.35);line-height:1.7;}
  .footer-col h4{font-size:0.75rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:12px;}
  .footer-col a{display:block;font-size:0.84rem;color:rgba(255,255,255,0.5);margin-bottom:8px;transition:color 0.2s;}
  .footer-col a:hover{color:var(--cyan);}
  .footer-bottom{max-width:1080px;margin:0 auto;padding-top:18px;border-top:1px solid rgba(255,255,255,0.06);display:flex;justify-content:space-between;flex-wrap:wrap;gap:10px;}
  .footer-bottom p{font-size:0.78rem;color:rgba(255,255,255,0.25);}
  .footer-bottom a{color:var(--cyan);opacity:0.6;}
  .footer-bottom a:hover{opacity:1;}

  /* FLOAT */
  .wa-float{position:fixed;bottom:24px;right:24px;width:58px;height:58px;background:#25D366;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(0,0,0,0.25);z-index:60;transition:transform 0.2s;}
  .wa-float:hover{transform:scale(1.1);}
  .wa-float svg{width:28px;height:28px;}

  /* RESPONSIVE */
  @media(max-width:900px){
    .hero-inner{grid-template-columns:1fr;}
    .hero-card{display:none;}
    .team-card{grid-template-columns:1fr;}
    .services-grid{grid-template-columns:1fr 1fr;}
    .why-grid{grid-template-columns:1fr 1fr;}
    .gallery-grid{grid-template-columns:1fr 1fr;}
    .process-steps{grid-template-columns:1fr 1fr;gap:24px;}
    .process-steps::before{display:none;}
    .contact-grid{grid-template-columns:1fr;}
    .footer-inner{grid-template-columns:1fr 1fr;}
    .nav-links a:not(.nav-cta){display:none;}
  }
  @media(max-width:560px){
    .services-grid{grid-template-columns:1fr;}
    .why-grid{grid-template-columns:1fr;}
    .gallery-grid{grid-template-columns:1fr;}
    .hero{padding:64px 20px 0;}
    .section{padding:52px 20px;}
    .footer-inner{grid-template-columns:1fr;}
  }
</style>
</head>
<body>

<header>
  <nav class="nav">
    <div class="logo">
      <img class="logo-img" src="data:image/jpeg;base64," alt="Clark's Cleaning Services logo">
      <div>
        <div class="logo-text">Clark's <span>Cleaning</span></div>
        <span class="logo-sub">Lincoln & Surrounding Areas</span>
      </div>
    </div>
    <div class="nav-links">
      <a href="#services">Services</a>
      <a href="#gallery">Our Work</a>
      <a href="#team">Our Team</a>
      <a href="#contact">Contact</a>
      <a href="https://wa.me/447513231640?text=Hi%2C%20I%27d%20like%20a%20free%20cleaning%20quote" class="nav-cta" target="_blank" rel="noopener">Free Quote</a>
    </div>
  </nav>
</header>

<div class="team-banner">
  <img src="data:image/jpeg;base64," alt="Meet Briene & Tom — Clark's Cleaning Services" style="width:100%;max-height:420px;object-fit:cover;object-position:center 30%;display:block;">
  <div class="team-banner-overlay">
    <div class="team-banner-content">
      <div class="hero-tag"><span class="dot"></span> Lincoln & Surrounding Areas</div>
      <h1 class="team-banner-title">Your Local Family-Run<br>Cleaning Team.</h1>
